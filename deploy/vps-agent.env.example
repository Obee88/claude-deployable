# /home/deploy/etc/vps-agent.env  —  systemd EnvironmentFile for vps-agent.
#
# Copy to /home/deploy/etc/vps-agent.env on the VPS, set tight perms
# (chmod 0600, owner deploy:deploy), fill in the placeholder values,
# and `sudo systemctl restart vps-agent`.
#
#   sudo install -d -o deploy -g deploy -m 0700 /home/deploy/etc
#   sudo cp /tmp/vps-agent.env.example /home/deploy/etc/vps-agent.env
#   sudo chown deploy:deploy /home/deploy/etc/vps-agent.env
#   sudo chmod 0600 /home/deploy/etc/vps-agent.env
#
# The agent refuses to start if VPS_READ_TOKEN, VPS_WRITE_TOKEN,
# VPS_ALLOWED_SERVICES, or VPS_COMPOSE_DIR are missing. That's
# intentional — fail loud at startup beats silent reject-everything
# at request time.

# --- Listen address ----------------------------------------------
# Caddy fronts the public hostname and reverse-proxies here, so
# binding to localhost is the right production default. Port 8090
# (NOT 8080) avoids colliding with the hello service from M2's
# compose.yml, which is bound to 127.0.0.1:8080.
VPS_LISTEN_ADDR=127.0.0.1:8090

# --- Bearer tokens -----------------------------------------------
# Two tokens, NOT one: read-token authorizes GET /containers, GET
# /containers/{name}/logs, GET /containers/{name}/health, and (in
# M3.B) GET /ci/runs. Write-token additionally authorizes
# POST /containers/{name}/restart. Compromise of the read-token
# leaks observability but not the ability to bounce services.
#
# Generation (run once on a trusted machine, then paste here):
#   openssl rand -hex 32
#
# Both must be set; both must differ from each other in production.
VPS_READ_TOKEN=REPLACE_ME_READ_TOKEN_HEX
VPS_WRITE_TOKEN=REPLACE_ME_WRITE_TOKEN_HEX

# --- Service allowlist -------------------------------------------
# Comma-separated list of compose service names the agent is allowed
# to inspect, log, health-check, and restart. Any name NOT in this
# list returns 404 to /containers/{name}/* (we deliberately don't
# 403; less info leaks about what else is on the host).
#
# Start with just `hello`; widen as you add services.
VPS_ALLOWED_SERVICES=hello

# --- Compose project directory -----------------------------------
# Where compose.yml lives on this VPS. Must match VPS_COMPOSE_DIR
# repo secret. Restart shells `docker compose -f $VPS_COMPOSE_DIR/
# compose.yml restart <service>`, so this MUST point at a directory
# containing a compose.yml that defines every service in the
# allowlist.
VPS_COMPOSE_DIR=/home/deploy/claude-deployable
