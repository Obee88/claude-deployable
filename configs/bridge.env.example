# claude-deployable bridge configuration.
#
# Reference file.  Run ./scripts/bootstrap.sh from the repo root to
# generate a real .env with paths matching this clone, then paste your
# GH_PAT into it.  Manual path: cp configs/bridge.env.example .env &&
# chmod 600 .env, then edit CLAUDE_DEPLOYABLE_ALLOWLIST and GH_PAT.
#
# The bridge refuses to start without an allowlist and a configured
# commit identity.  At runtime it auto-discovers .env by walking up
# from cwd to the nearest .git/ boundary; CLAUDE_DEPLOYABLE_ENV is the
# explicit override.

# ----------------------------------------------------------------------
# Repo allowlist.  Comma-separated absolute paths.  Any tool call whose
# `repo` argument resolves outside this set is rejected with the
# structured error code `outside_allowlist`.  Symlinks are resolved
# before the comparison, so it is safe to allow a canonical path and
# call from a symlinked path (or vice-versa).
# ----------------------------------------------------------------------
CLAUDE_DEPLOYABLE_ALLOWLIST=/Users/you/coding/claude-deployable

# ----------------------------------------------------------------------
# Commit identity used for GIT_AUTHOR_*/GIT_COMMITTER_* on every commit
# the bridge makes.  See PLAN.md for why we use a noreply identity
# rather than a real GitHub account.
# ----------------------------------------------------------------------
GIT_AUTHOR_NAME=claude-agent
GIT_AUTHOR_EMAIL=claude-agent@users.noreply.github.com

# ----------------------------------------------------------------------
# GitHub fine-grained PAT.
#
# Required scopes:
#   * Contents: Read & write   (push commits)
#   * Metadata: Read-only      (always required)
#   * Actions:  Read-only      (added in M2 for ci_wait_for_run / ci_logs)
#
# Repository access: limit to the repos in CLAUDE_DEPLOYABLE_ALLOWLIST.
# Recommended expiration: 90 days, so an un-rotated token surfaces as
# an auth failure rather than a silent risk.
#
# The bridge injects this PAT into the remote URL on each push and
# never persists it to .git/config.
# ----------------------------------------------------------------------
GH_PAT=ghp_replace_me
