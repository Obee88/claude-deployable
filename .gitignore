# Bridge runtime config — contains the GH_PAT, lives at the repo root by
# design (see SETUP.md §4 and PLAN.md "secrets" decision row).  Must
# never be committed.  The committed reference is configs/bridge.env.example.
.env
.env.local
.env.*.local

# Built binaries.  `go build -o ./bridge ./cmd/bridge` and equivalents
# for the VPS agent should not be tracked.
/bridge
/vps-agent
*.exe

# Editor / OS cruft
.DS_Store
.idea/
.vscode/
*.swp
*~

# Go test / coverage artefacts
*.test
*.out
coverage.txt
